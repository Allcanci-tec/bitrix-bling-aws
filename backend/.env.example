# Exemplo de arquivo .env - COPIE PARA .env.local E PREENCHA COM VALORES REAIS
# Nunca commit o .env.local com valores reais!

# Bling OAuth
BLING_CLIENT_ID=seu_client_id_aqui
BLING_CLIENT_SECRET=seu_client_secret_aqui
BLING_ACCESS_TOKEN=seu_access_token_aqui
BLING_REFRESH_TOKEN=seu_refresh_token_aqui
BLING_REDIRECT_URI=https://seu-dominio.com/callback

# Bitrix24
BITRIX_TOKEN=seu_bitrix_token_aqui
BITRIX_WEBHOOK_URL=https://sua-empresa.bitrix24.com.br/rest/...
BITRIX_USER_ID=seu_user_id

# Redis/Cache (Upstash)
UPSTASH_REDIS_REST_URL=https://seu-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=seu_redis_token_aqui
REDIS_KEY_NAME=token-bling-bitrix

# Vercel
VERCEL_API_TOKEN=seu_vercel_token_aqui
VERCEL_PROJECT_ID=seu_project_id_aqui
VERCEL_OIDC_TOKEN=seu_oidc_token_aqui

# Flask
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=3000

# Ngrok (local development)
NGROK_URL=https://seu-ngrok-url.ngrok-free.dev

# Auto-renewer
BLING_RENEW_CHECK_SECONDS=900
BLING_RENEW_BEFORE_SECONDS=1800
